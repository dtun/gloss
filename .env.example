# Anthropic API key — required to generate real glosses.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Port the server listens on (serves both the API and the built frontend).
PORT=8787

# Set to 1 to skip the Anthropic call and return a deterministic stub.
# Used by the e2e suite so it runs without an API key. Leave unset for real use.
# GLOSS_FAKE_LLM=1
